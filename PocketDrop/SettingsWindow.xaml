<Window x:Class="PocketDrop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Text_SettingsTitle}" Height="700" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MicaBase}" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        Icon="/Assets/PocketDrop.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="AnimatedPanel" TargetType="StackPanel">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="6" Margin="4,0"/>
                            <Border x:Name="ActiveIndicator" Width="3" Height="16" CornerRadius="1.5" Background="#005FB8" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" Margin="4,0,0,0"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource LayerAlt}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource LayerAlt}"/>
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="StatusText" Text="{DynamicResource Text_ToggleOff}" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="14"/>

                            <Border x:Name="Border" Width="40" Height="20" CornerRadius="10" Background="{DynamicResource LayerAlt}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1">
                                <Ellipse x:Name="Thumb" Width="14" Height="14" Fill="{DynamicResource TextSecondary}" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="StatusText" Property="Text" Value="{DynamicResource Text_ToggleOn}"/>

                                <Setter TargetName="Border" Property="Background" Value="#005FB8"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#005FB8"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="CheckBoxBorder" Width="20" Height="20" CornerRadius="4" 
                                    BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1.5" Background="{DynamicResource LayerAlt}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <Path x:Name="CheckMark" Data="M 1 5 L 4 8 L 10 1" 
                                      Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round" 
                                      Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Stretch="Uniform" Width="11" Height="8"/>
                            </Border>
                            <TextBlock Text="{TemplateBinding Content}" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#005FB8"/>
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#005FB8"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#0053A0"/>
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#0053A0"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeCardDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource LayerAlt}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource LayerDefault}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeControlDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0,30,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="6">

                                            <Path x:Name="Arrow" Data="M 0 0 L 4 4 L 8 0" 
                                                  Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource LayerAlt}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource LayerAlt}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter IsHitTestVisible="False"
                                              Margin="{TemplateBinding Padding}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="Left"/>

                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Name="DropDown" Background="{DynamicResource LayerDefault}" BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="1" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}" Margin="0,4,0,15">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.2" Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Bd" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconHaloBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LayerAlt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShortcutBox" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeControlDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="{DynamicResource LayerAlt}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Keycap" TargetType="Border">
            <Setter Property="Background" Value="#005FB8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="MinWidth" Value="32"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10,40,10,10">
            <StackPanel Orientation="Horizontal" Margin="20,0,0,30">
                <TextBlock Text="{DynamicResource Text_SettingsTitle}" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>

            <RadioButton x:Name="NavAppearance" GroupName="SettingsNav" Style="{StaticResource NavRadioButtonStyle}" IsChecked="True">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M 5 3 C 3.89 3 3 3.89 3 5 L 3 19 C 3 20.11 3.89 21 5 21 L 19 21 C 20.11 21 21 20.11 21 19 L 21 5 C 21 3.89 20.11 3 19 3 Z M 3 9 L 21 9 M 9 21 L 9 9" 
              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" 
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" 
              Stretch="Uniform" Width="18" Height="18" Margin="8,0,16,0"/>
                    <TextBlock Text="{DynamicResource Text_AppearanceBehavior}" VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="NavShortcut" GroupName="SettingsNav" Style="{StaticResource NavRadioButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z" 
              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" 
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" 
              Stretch="Uniform" Width="18" Height="18" Margin="8,0,16,0"/>
                    <TextBlock Text="{DynamicResource Text_ShortcutHeader}" VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="NavShelf" GroupName="SettingsNav" Style="{StaticResource NavRadioButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M 3 3 H 10 V 10 H 3 V 3 Z M 14 3 H 21 V 10 H 14 V 3 Z M 14 14 H 21 V 21 H 14 V 14 Z M 3 14 H 10 V 21 H 3 V 14 Z" 
              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" 
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" 
              Stretch="Uniform" Width="18" Height="18" Margin="8,0,16,0"/>
                    <TextBlock Text="{DynamicResource Text_PocketPreferences}" VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="NavAbout" GroupName="SettingsNav" Style="{StaticResource NavRadioButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M 12 22 C 17.52 22 22 17.52 22 12 C 22 6.48 17.52 2 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 Z M 12 16 L 12 12 M 12 8 L 12.01 8" 
              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" 
              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" 
              Stretch="Uniform" Width="18" Height="18" Margin="8,0,16,0"/>
                    <TextBlock Text="{DynamicResource Text_AboutHeader}" VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <Border Grid.Column="1" Background="{DynamicResource LayerDefault}" 
        CornerRadius="12" Margin="10,15,10,15" 
        BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.1" Direction="270" Color="Black"/>
            </Border.Effect>

            <ScrollViewer Padding="40,40,40,40" Margin="2">
                <Grid>
                    <StackPanel x:Name="AppearancePanel" Style="{StaticResource AnimatedPanel}" Visibility="{Binding IsChecked, ElementName=NavAppearance, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource Text_AppearanceBehavior}" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                    <Border Style="{DynamicResource SettingCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M 4 21 L 4 14 M 4 10 L 4 3 M 12 21 L 12 12 M 12 8 L 12 3 M 20 21 L 20 16 M 20 12 L 20 3 M 1 14 L 7 14 M 9 8 L 15 8 M 17 16 L 23 16" Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Stretch="Uniform" Width="18" Height="18" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource Text_AppTheme}" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                            <ComboBox x:Name="ThemeCombo" Grid.Column="2" Width="160" VerticalAlignment="Center" SelectedIndex="0" Style="{StaticResource ModernComboBox}" SelectionChanged="ThemeCombo_SelectionChanged">
                                <ComboBoxItem Content="{DynamicResource Text_ThemeSystem}"/>
                                <ComboBoxItem Content="{DynamicResource Text_ThemeLight}"/>
                                <ComboBoxItem Content="{DynamicResource Text_ThemeDark}"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{DynamicResource SettingCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M 12 2 C 17.52 2 22 6.48 22 12 C 22 17.52 17.52 22 12 22 C 6.48 22 2 17.52 2 12 C 2 6.48 6.48 2 12 2 Z M 2 12 L 22 12 M 12 2 C 14.5 4.74 16 8.29 16 12 C 16 15.71 14.5 19.26 12 22 C 9.5 19.26 8 15.71 8 12 C 8 8.29 9.5 4.74 12 2 Z" Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Width="20" Height="20" HorizontalAlignment="Left"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Text_AppLanguage}" FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <ComboBox x:Name="LanguageCombo" Grid.Column="2" Width="160" VerticalAlignment="Center" SelectedIndex="0" Style="{StaticResource ModernComboBox}" SelectionChanged="LanguageCombo_SelectionChanged">
                                <ComboBoxItem Content="{DynamicResource Text_LangEnglish}"/>
                                <ComboBoxItem Content="{DynamicResource Text_LangVietnamese}"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Style="{DynamicResource SettingCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                                <Path Data="M 18 13 V 19 C 18 20.11 17.11 21 16 21 H 5 C 3.89 21 3 20.11 3 19 V 8 C 3 6.89 3.89 6 5 6 H 11 M 15 3 H 21 V 9 M 10 14 L 21 3" 
                                      Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" 
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" 
                                      Stretch="Uniform" Width="18" Height="18" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Text_RunAtStartup}" FontSize="14" Foreground="{DynamicResource TextPrimary}" Margin="0,0,20,0"/>
                                <TextBlock Text="{DynamicResource Text_RunAtStartupDesc}" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,2,20,0"/>
                            </StackPanel>
                                <CheckBox x:Name="StartupToggle" Grid.Column="2" Content="{DynamicResource Text_ToggleOn}" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Click="StartupToggle_Click"/>
                            </Grid>
                    </Border>

                    <Border Style="{DynamicResource SettingCard}">
                        <StackPanel>
                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                    <Path Data="M8 16H6C4.895 16 4 15.105 4 14V6C4 4.895 4.895 4 6 4H14C15.105 4 16 4.895 16 6V8 M10 8H18C19.105 8 20 8.895 20 10V18C20 19.105 19.105 20 18 20H10C8.895 20 8 19.105 8 18V10C8 8.895 8.895 8 10 8Z" 
                                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" 
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" 
                                          Stretch="Uniform" Width="18" Height="18" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Text_CopyItems}" FontSize="14" Foreground="{DynamicResource TextPrimary}" Margin="0,0,20,0"/>
                                    <TextBlock Text="{DynamicResource Text_CopyItemsDesc}" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,2,20,0"/>
                                </StackPanel>
                                <CheckBox x:Name="CopyItemToDestinationCheckbox" Grid.Column="2" Content="{DynamicResource Text_ToggleOn}" IsChecked="True" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" Click="Copy_Click" Margin="0,0,10,0"/>
                                <ToggleButton x:Name="ExpandDescButton" Grid.Column="3" Width="24" Height="24" Background="Transparent" BorderThickness="0" Cursor="Hand" Focusable="False">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <Path x:Name="Chevron" Data="M 5 9 L 12 15 L 19 9" Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Chevron" Property="Data" Value="M 5 15 L 12 9 L 19 15"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Chevron" Property="Stroke" Value="{DynamicResource TextPrimary}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>

                            <Border Margin="-15,15,-15,-15" Padding="35,16,35,20" Background="{DynamicResource LayerAlt}" BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8"
                                Visibility="{Binding IsChecked, ElementName=ExpandDescButton, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{DynamicResource Text_CopyItemsHint}" TextWrapping="Wrap" TextAlignment="Justify" Foreground="{DynamicResource TextSecondary}" FontSize="13" LineHeight="22"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                    <StackPanel x:Name="ShortcutPanel" Style="{StaticResource AnimatedPanel}" Visibility="{Binding IsChecked, ElementName=NavShortcut, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource Text_ShortcutHeader}" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                    <Border Style="{DynamicResource SettingCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                                <Path Data="M 11 4 H 4 a 2 2 0 0 0 -2 2 v 14 a 2 2 0 0 0 2 2 h 14 a 2 2 0 0 0 2 -2 v -7 M 18.5 2.5 a 2.121 2.121 0 0 1 3 3 L 12 15 l -4 1 l 1 -4 l 9.5 -9.5 z" 
                                      Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" 
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" 
                                      Stretch="Uniform" Width="18" Height="18" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Text_NewPocketShortcut}" FontSize="14" Foreground="{DynamicResource TextPrimary}" Margin="0,0,20,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{DynamicResource Text_NewPocketShortcutDesc}" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,2,20,0"/>
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource ShortcutBox}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource Keycap}">
                                        <Path Data="M3 3H11V11H3V3ZM13 3H21V11H13V3ZM3 13H11V21H3V13ZM13 13H21V21H13V13Z" Fill="White" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="Shift" Foreground="White" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock x:Name="PocketKeyText" Text="Z" Foreground="White" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Background="Transparent" Cursor="Hand" MouseLeftButtonDown="EditPocketKey_Click">
