                    <Border Grid.Row="2" BorderBrush="#E5E5E5" BorderThickness="0,1,0,0" Padding="0,16,0,16">
                        <Button Content="Close" Width="120" Height="32" HorizontalAlignment="Right" Click="CloseLicense_Click" Cursor="Hand" Foreground="#111111" FontSize="13">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" x:Name="BtnBorder">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#F5F5F5"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#E5E5E5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
