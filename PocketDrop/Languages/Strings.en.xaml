<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    
    <!-- Main Window -->
    <sys:String x:Key="Text_MenuOpenWith">Open with...</sys:String>
    <sys:String x:Key="Text_MenuShare">Share...</sys:String>
    <sys:String x:Key="Text_MenuCompressZip">Compress to ZIP...</sys:String>
    <sys:String x:Key="Text_MenuClearItems">Clear all items</sys:String>
    <sys:String x:Key="Text_MenuOpenTempFolder">Open Temp Folder</sys:String>
    <sys:String x:Key="Text_MenuSettings">Settings</sys:String>
    <sys:String x:Key="Text_DropItemsHere">Drop items here</sys:String>
    <sys:String x:Key="Text_SelectAll">Select all</sys:String>
    <sys:String x:Key="Text_0Items">0 items</sys:String>
    <sys:String x:Key="Text_Item">item</sys:String>
    <sys:String x:Key="Text_Items">items</sys:String>
    <sys:String x:Key="Text_FileSelected">file selected</sys:String>
    <sys:String x:Key="Text_FilesSelected">files selected</sys:String>
    
    <!-- Saved Pockets Window -->
    <sys:String x:Key="Text_SavedPocketsTitle">Saved Pockets</sys:String>
    <sys:String x:Key="Text_EmptyPockets" xml:space="preserve">Your Pockets will appear here&#x0a;when you close them.</sys:String>
    <sys:String x:Key="Text_AddPocketTooltip">Add new pocket</sys:String>
    <sys:String x:Key="Text_DeleteAllTooltip">Delete all pockets</sys:String>
    <sys:String x:Key="Text_SettingsTooltip">Settings</sys:String>
    <sys:String x:Key="Text_ClearAllPocketsTitle">Clear all pockets?</sys:String>
    <sys:String x:Key="Text_ClearAllPocketsDesc">This will close all windows and clear the list.</sys:String>
    <sys:String x:Key="Text_Cancel">Cancel</sys:String>
    <sys:String x:Key="Text_Delete">Delete</sys:String>
    
    <!-- Settings Window -->
    <sys:String x:Key="Text_SettingsTitle">Settings</sys:String>
    <sys:String x:Key="Text_AppearanceBehavior">Appearance and behavior</sys:String>
    <sys:String x:Key="Text_AppTheme">App theme</sys:String>
    <sys:String x:Key="Text_ThemeSystem">System</sys:String>
    <sys:String x:Key="Text_ThemeLight">Light</sys:String>
    <sys:String x:Key="Text_ThemeDark">Dark</sys:String>
    <sys:String x:Key="Text_AppLanguage">App language</sys:String>
    <sys:String x:Key="Text_LangEnglish">English</sys:String>
    <sys:String x:Key="Text_LangVietnamese">Vietnamese</sys:String>
    <sys:String x:Key="Text_RunAtStartup">Run at startup</sys:String>
    <sys:String x:Key="Text_RunAtStartupDesc">PocketDrop will launch automatically</sys:String>
    <sys:String x:Key="Text_ToggleOn">On</sys:String>
    <sys:String x:Key="Text_CopyItems">Copy items to destination</sys:String>
    <sys:String x:Key="Text_CopyItemsDesc">Dragged items from pocket will be copied instead of moved</sys:String>
    <sys:String x:Key="Text_CopyItemsHint">By default, PocketDrop copies items from your Pocket when they are dragged out and moves them to your destination. Enabling this setting will make copying the default behaviour. If you want to move the file to destination completely, please disable this setting.</sys:String>

    <sys:String x:Key="Text_ShortcutHeader">Shortcut</sys:String>
    <sys:String x:Key="Text_NewPocketShortcut">New pocket shortcut</sys:String>
    <sys:String x:Key="Text_NewPocketShortcutDesc">Customize the shortcut to open a new pocket</sys:String>
    <sys:String x:Key="Text_ClipboardShortcut">New pocket from clipboard shortcut</sys:String>
    <sys:String x:Key="Text_ClipboardShortcutDesc">Customize the shortcut to open a new pocket using the clipboard</sys:String>
    <sys:String x:Key="Text_ShakeMouse">Shake mouse to open new Pocket</sys:String>
    <sys:String x:Key="Text_ShakeMouseDesc">Shake your mouse while dragging items to open a new Pocket</sys:String>
    <sys:String x:Key="Text_ShakeDistance">Shake minimum distance</sys:String>
    <sys:String x:Key="Text_ShakeDistanceDesc">The minimum distance for mouse shaking activation, for adjusting sensitivity</sys:String>
    <sys:String x:Key="Text_GameModeCheck">Do not open Pocket when Game Mode is on</sys:String>
    <sys:String x:Key="Text_ExcludedApps">Excluded apps</sys:String>
    <sys:String x:Key="Text_ExcludedAppsDesc">Prevent mouse shake shortcut from activating when an excluded app is in the foreground</sys:String>
    <sys:String x:Key="Text_ExcludedAppsHint1">Add an application's name, or part of the name, one per line (e.g. adding Notepad will match both Notepad.exe and Notepad++.exe; to match only Notepad.exe add the .exe extension).</sys:String>
    <sys:String x:Key="Text_ExcludedAppsHint2">Press Enter to add a new line. Your changes are saved automatically when you click outside the box.</sys:String>

    <sys:String x:Key="Text_PocketPreferences">Pocket preferences</sys:String>
    <sys:String x:Key="Text_ShelfPlacement">Pocket placement</sys:String>
    <sys:String x:Key="Text_ShelfPlacementDesc">Change where a new Pocket is placed upon opening</sys:String>
    <sys:String x:Key="Text_PlacementMouse">Near mouse pointer</sys:String>
    <sys:String x:Key="Text_PlacementTop">Top edge</sys:String>
    <sys:String x:Key="Text_PlacementBottom">Bottom edge</sys:String>
    <sys:String x:Key="Text_PlacementLeft">Left edge</sys:String>
    <sys:String x:Key="Text_PlacementRight">Right edge</sys:String>
    <sys:String x:Key="Text_PlacementTopLeft">Top left corner</sys:String>
    <sys:String x:Key="Text_PlacementTopRight">Top right corner</sys:String>
    <sys:String x:Key="Text_PlacementBottomLeft">Bottom left corner</sys:String>
    <sys:String x:Key="Text_PlacementBottomRight">Bottom right corner</sys:String>

    <sys:String x:Key="Text_ItemsLayoutMode">Items layout mode</sys:String>
    <sys:String x:Key="Text_ItemsLayoutModeDesc">Change the default layout mode in the shelf flyout</sys:String>
    <sys:String x:Key="Text_LayoutGrid">Grid view</sys:String>
    <sys:String x:Key="Text_LayoutList">List view</sys:String>
    <sys:String x:Key="Text_CloseEmptied">Close pocket when emptied</sys:String>
    <sys:String x:Key="Text_CloseEmptiedDesc">Automatically close pockets once all items have been dragged out</sys:String>

    <sys:String x:Key="Text_AboutHeader">About</sys:String>
    <sys:String x:Key="Text_Copyright">2026 Nao. All rights reserved.</sys:String>
    <sys:String x:Key="Text_PrivacyPolicy">Privacy policy</sys:String>
    <sys:String x:Key="Text_ThirdParty">Third party licenses</sys:String>
    <sys:String x:Key="Text_RateReview">Rate and review on the Microsoft Store</sys:String>
    <sys:String x:Key="Text_GetHelp">Get help</sys:String>
    <sys:String x:Key="Text_GetHelpDesc">Report a bug, request features, or contact the developer</sys:String>

    <sys:String x:Key="Text_PrivacyP1">PocketDrop does not collect, store or share your personal information or data. The app only locally accesses user data such as files and folders from the local device, content from the clipboard, and device information in order to make the app function properly. This data is not transmitted, collected, or shared with any third parties.</sys:String>
    <sys:String x:Key="Text_PrivacyP2">PocketDrop collects anonymous information about crashes and hangs. The information we collect is non-identifiable and does not include any personal data. We do not share collected information with any third parties.</sys:String>
    <sys:String x:Key="Text_PrivacyP3">We may modify or update this privacy policy from time to time. When we change this policy, we will inform you of such changes by updating the &quot;Effective date&quot; notice. Users should review this privacy policy periodically.</sys:String>
    <sys:String x:Key="Text_PrivacyDate">Effective date: March 25, 2026</sys:String>
    <sys:String x:Key="Text_Close">Close</sys:String>
    <sys:String x:Key="Text_LicenseIntro">PocketDrop is made possible by the following open-source software and assets:</sys:String>

    <!-- Shortcut Dialog -->
    <sys:String x:Key="Text_EditShortcutTitle">Edit Shortcut</sys:String>
    <sys:String x:Key="Text_PressLetterKey">Press a letter key (A-Z) to change this shortcut.</sys:String>
    <sys:String x:Key="Text_ModifiersLocked">Modifiers (Win + Shift) are locked to ensure system stability.</sys:String>
    <sys:String x:Key="Text_Save">Save</sys:String>

    <!-- Tray Menu -->
    <sys:String x:Key="Text_TrayAddPocket">Add Pocket</sys:String>
    <sys:String x:Key="Text_TrayAddClipboard">Add Pocket from clipboard</sys:String>
    <sys:String x:Key="Text_TraySavedPockets">Saved Pockets</sys:String>
    <sys:String x:Key="Text_TraySettings">Settings</sys:String>
    <sys:String x:Key="Text_TrayReportBug">Report bug</sys:String>
    <sys:String x:Key="Text_TrayQuit">Quit PocketDrop</sys:String>

</ResourceDictionary>