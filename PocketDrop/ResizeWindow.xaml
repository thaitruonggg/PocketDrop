<Window x:Class="PocketDrop.ResizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Text_ResizeImagesTitle}" Height="400" Width="440"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#005FB8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#004A91"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#003E7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource LayerDefault}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource IconHaloBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource LayerAlt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Win11ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="SelectedIndicator" Width="3" Height="16" Background="#005FB8" CornerRadius="1.5" HorizontalAlignment="Left" Margin="-8,0,0,0" Visibility="Collapsed"/>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LayerAlt}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LayerAlt}"/>
                                <Setter TargetName="SelectedIndicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Win11ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource CardBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeControlDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                            <Border x:Name="HoverOverlay" Background="Transparent" CornerRadius="4">
                                                <Path Fill="{DynamicResource TextSecondary}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Border>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HoverOverlay" Property="Background" Value="#0A000000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource CardBase}" BorderThickness="1" BorderBrush="{DynamicResource StrokeControlDefault}" CornerRadius="4" Margin="0,4,0,0" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer Margin="0,4">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource LayerDefault}" BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="1" CornerRadius="8" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15" Direction="270" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="24,24,24,0">
                <TextBlock Text="{DynamicResource Text_ResizeImagesTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                <TextBlock Text="{DynamicResource Text_ResizeImagesDesc}" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,24"/>

                <Grid Margin="0,0,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="{DynamicResource Text_Width}" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                        <Border Background="{DynamicResource CardBase}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1" CornerRadius="4">
                            <TextBox x:Name="WidthInput" Padding="8,6" FontSize="14" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" PreviewTextInput="NumberValidation"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="✕" VerticalAlignment="Bottom" Margin="16,0,16,10" Foreground="{DynamicResource TextSecondary}" FontSize="14" FontWeight="Bold"/>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="{DynamicResource Text_Height}" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                        <Border Background="{DynamicResource CardBase}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1" CornerRadius="4">
                            <TextBox x:Name="HeightInput" Padding="8,6" FontSize="14" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" PreviewTextInput="NumberValidation"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="{DynamicResource Text_ResizeMode}" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ModeCombo" SelectedIndex="0" FontSize="14" Style="{StaticResource Win11ComboBoxStyle}" ItemContainerStyle="{StaticResource Win11ComboBoxItemStyle}">
                            <ComboBoxItem Content="{DynamicResource Text_ModeFit}"/>
                            <ComboBoxItem Content="{DynamicResource Text_ModeFill}"/>
                            <ComboBoxItem Content="{DynamicResource Text_ModeStretch}"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="{DynamicResource Text_Unit}" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,6" FontWeight="SemiBold"/>
                        <ComboBox x:Name="UnitCombo" SelectedIndex="0" FontSize="14" Style="{StaticResource Win11ComboBoxStyle}" ItemContainerStyle="{StaticResource Win11ComboBoxItemStyle}">
                            <ComboBoxItem Content="{DynamicResource Text_UnitPixels}"/>
                            <ComboBoxItem Content="{DynamicResource Text_UnitPercentages}"/>
                            <ComboBoxItem Content="{DynamicResource Text_UnitCentimeters}"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Border Grid.Row="1" Background="{DynamicResource LayerAlt}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="{DynamicResource Text_ResizeBtn}" Click="Apply_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Grid.Column="1" Content="{DynamicResource Text_Cancel}" Click="Cancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>