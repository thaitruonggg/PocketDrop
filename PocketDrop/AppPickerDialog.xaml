<Window x:Class="PocketDrop.AppPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Apps" Height="550" Width="600"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource LayerDefault}" FontFamily="Segoe UI Variable, Segoe UI, sans-serif">

    <Window.Resources>
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="CheckBoxBorder" Width="20" Height="20" CornerRadius="4" 
                                    BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1.5" Background="{DynamicResource LayerAlt}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <Path x:Name="CheckMark" Data="M 1 5 L 4 8 L 10 1" 
                                      Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round" 
                                      Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Stretch="Uniform" Width="11" Height="8"/>
                            </Border>
                            <TextBlock Text="{TemplateBinding Content}" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#005FB8"/>
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#005FB8"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource TextSecondary}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="#0053A0"/>
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#0053A0"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource Text_SelectAppsHeader}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

        <StackPanel x:Name="LoadingPanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{DynamicResource Text_ScanningApps}" FontSize="16" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
            <TextBlock Text="{DynamicResource Text_ScanningDesc}" FontSize="13" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,8,0,0" Opacity="0.7"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="AppListControl" Visibility="Collapsed">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="100" Height="110" Margin="8" Background="Transparent" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Image Source="{Binding AppIcon}" Width="48" Height="48" Margin="0,15,0,0" VerticalAlignment="Top"/>

                                <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6" Style="{StaticResource ModernCheckBox}"/>

                                <TextBlock Grid.Row="1" Text="{Binding AppName}" FontSize="12" Foreground="{DynamicResource TextPrimary}" 
                                           TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="4,8,4,8"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="{DynamicResource Text_CannotFindApp}" FontSize="13" Foreground="{DynamicResource AccentText}" Cursor="Hand" TextDecorations="Underline" VerticalAlignment="Center" HorizontalAlignment="Left" MouseLeftButtonDown="ManualBrowse_Click"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Text_Cancel}" Width="100" Height="32" Margin="0,0,10,0" Click="Cancel_Click" Cursor="Hand" Foreground="{DynamicResource TextPrimary}" Background="Transparent" BorderBrush="{DynamicResource StrokeControlDefault}"/>
                <Button Content="{DynamicResource Text_Save}" Width="100" Height="32" Click="Save_Click" Cursor="Hand" Foreground="White" Background="#005FB8" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>