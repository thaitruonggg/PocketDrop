<Window x:Class="PocketDrop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PocketDrop" Height="200" Width="200"
        AllowsTransparency="True" WindowStyle="None" Topmost="True" Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality"
        FontFamily="Segoe UI Variable Text, Segoe UI" TextOptions.TextFormattingMode="Display"
        Icon="/Assets/PocketDrop.ico">

    <Window.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <DataTemplate x:Key="UnifiedItemTemplate">
            <Grid>

                <StackPanel x:Name="GridUI" Margin="5" Width="96" UseLayoutRounding="True" Visibility="Visible">
                    <Border CornerRadius="6" Background="Transparent" Width="90" Height="90" ClipToBounds="True">
                        <Image Source="{Binding Icon}" Stretch="Uniform" UseLayoutRounding="True" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="{DynamicResource TextPrimary}" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,5,0,0"/>
                </StackPanel>

                <Border x:Name="ListUI" Margin="0,3" Width="475" CornerRadius="8" Padding="12,10" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="6" Width="48" Height="48" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" ClipToBounds="True">
                            <Image Source="{Binding Icon}" UseLayoutRounding="True" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource TextPrimary}" Margin="14,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

            </Grid>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding CurrentViewMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="List">
                    <Setter TargetName="GridUI" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ListUI" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <ControlTemplate x:Key="MoreButtonTemplate" TargetType="Button">
            <Grid Background="Transparent">
                <Border CornerRadius="12" Background="{DynamicResource IconHaloBackground}" />
                <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0.3,0">
                    <Canvas Width="24" Height="24">
                        <Path Fill="{DynamicResource TextSecondary}" Data="M5,10 a2,2 0 1,1 0,4 a2,2 0 1,1 0,-4 z M12,10 a2,2 0 1,1 0,4 a2,2 0 1,1 0,-4 z M19,10 a2,2 0 1,1 0,4 a2,2 0 1,1 0,-4 z"/>
                    </Canvas>
                </Viewbox>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="ExpandToggleTemplate" TargetType="ToggleButton">
            <Border Background="{DynamicResource LayerDefault}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1" CornerRadius="6" Padding="14,5">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="DeleteButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20" x:Name="BtnBorder">
                <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-1.5,0,1.5,0">
                    <Path x:Name="TrashIcon" Data="M3 6H21 M19 6V20C19 21.1046 18.1046 22 17 22H7C5.89543 22 5 21.1046 5 20V6 M8 6V4C8 2.89543 8.89543 2 10 2H14C15.1046 2 16 2.89543 16 4V6 M10 11V17 M14 11V17" 
                          Stroke="{DynamicResource TextPrimary}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                </Viewbox>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="BtnBorder" Property="Background" Value="#1AD13438"/>
                    <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#D13438"/>
                    <Setter TargetName="TrashIcon" Property="Stroke" Value="#D13438"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="PocketContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{DynamicResource LayerDefault}" BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="1" CornerRadius="8" Padding="0,4">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PocketMenuItemStyle" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="BgBorder" Background="Transparent" CornerRadius="4" Margin="4,2">
                            <ContentPresenter Content="{TemplateBinding Header}" Margin="{TemplateBinding Padding}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#0F000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FullWidthSeparator" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Rectangle Height="1" Grid.ColumnSpan="3" Fill="{DynamicResource StrokeControlDefault}" SnapsToDevicePixels="True" Margin="-4,6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PocketListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" CornerRadius="6" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" Padding="2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#400078D4"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#880078D4"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="#1A0078D4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PocketListBoxStyle" TargetType="ListBox">
            <Setter Property="ItemTemplate" Value="{StaticResource UnifiedItemTemplate}"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>

        </Style>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" Timeline.DesiredFrameRate="{x:Null}">

                    <DoubleAnimation Storyboard.TargetName="Blob1Transform" Storyboard.TargetProperty="X" 
                     From="0" To="180" Duration="0:0:9" AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Blob1Transform" Storyboard.TargetProperty="Y" 
                     From="0" To="150" Duration="0:0:15" AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation Storyboard.TargetName="Blob2Transform" Storyboard.TargetProperty="X" 
                     From="0" To="-160" Duration="0:0:11" AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Blob2Transform" Storyboard.TargetProperty="Y" 
                     From="0" To="-180" Duration="0:0:17" AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>

        <Border x:Name="MainContainer" Margin="12" Background="{DynamicResource MicaBase}" BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="1" CornerRadius="12"
                RenderTransformOrigin="0.5,0.5" AllowDrop="True" Drop="Window_Drop" DragEnter="Window_DragEnter" DragLeave="Window_DragLeave"
                PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp" MouseMove="Window_MouseMove">

            <Border.CacheMode>
                <BitmapCache EnableClearType="True" RenderAtScale="1" SnapsToDevicePixels="True"/>
            </Border.CacheMode>

            <Border.Effect>
                <DropShadowEffect BlurRadius="24" Color="#000000" Opacity="0.12" Direction="270" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Canvas Grid.RowSpan="3" ClipToBounds="True" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                    <Canvas.CacheMode>
                        <BitmapCache RenderAtScale="1" SnapsToDevicePixels="True"/>
                    </Canvas.CacheMode>
                    
                    <Ellipse Width="150" Height="150" Fill="#EA5B6F" Opacity="0.23" Canvas.Left="-30" Canvas.Top="-30">
                        <Ellipse.Effect>
                            <BlurEffect Radius="25" RenderingBias="Performance"/>
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Blob1Transform" X="0" Y="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse Width="120" Height="120" Fill="#77BEF0" Opacity="0.23" Canvas.Right="-20" Canvas.Bottom="-20">
                        <Ellipse.Effect>
                            <BlurEffect Radius="25" RenderingBias="Performance"/>
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Blob2Transform" X="0" Y="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                </Canvas>

                <Grid Grid.Row="0" x:Name="TopBar" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">

                    <Rectangle x:Name="DragHandle" Width="32" Height="5" RadiusX="2" RadiusY="2" Fill="{DynamicResource TextSecondary}" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0" Width="26" Height="26">
                        <Border CornerRadius="12" Background="{DynamicResource IconHaloBackground}" />
                        <TextBlock x:Name="CloseButton" Text="✕" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                   TextAlignment="Center" Padding="0,4,1,0" Cursor="Hand" Background="Transparent" MouseLeftButtonDown="CloseButton_Click"/>
                    </Grid>

                    <Button x:Name="MoreButton" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" Width="26" Height="26" Cursor="Hand" 
                            Click="MoreButton_Click" Template="{StaticResource MoreButtonTemplate}">
                        <Button.ContextMenu>
                            <ContextMenu Style="{StaticResource PocketContextMenuStyle}" FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="13" Foreground="{DynamicResource TextPrimary}">
                                <ContextMenu.Resources>
                                    <Style TargetType="MenuItem" BasedOn="{StaticResource PocketMenuItemStyle}"/>
                                </ContextMenu.Resources>
                                <MenuItem x:Name="Menu_DynamicOpen" Header="{DynamicResource Text_MenuOpenWith}" Click="Menu_DynamicOpen_Click" />
                                <MenuItem Header="{DynamicResource Text_MenuShare}" Click="Menu_Share_Click" />
                                <MenuItem Header="{DynamicResource Text_MenuCompressZip}" Click="Menu_CompressZip_Click" />
                                <MenuItem Header="{DynamicResource Text_MenuClearItems}" Click="Menu_ClearItems_Click" />
                                <MenuItem Style="{StaticResource FullWidthSeparator}" IsEnabled="False"/>
                                <MenuItem Header="{DynamicResource Text_MenuSettings}" Click="Menu_Settings_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="12,0">
                    <TextBlock x:Name="StatusText" Text="{DynamicResource Text_DropItemsHere}" FontSize="16" Foreground="{DynamicResource TextSecondary}"
                               FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Grid x:Name="FileIconContainer" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Width="150" Height="120" UseLayoutRounding="True">
                        <Grid x:Name="StackContainer"/>
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,8,0,12">
                    <ToggleButton x:Name="ExpandButton" Cursor="Hand" Template="{StaticResource ExpandToggleTemplate}">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                <TextBlock x:Name="CountNumberText" Text="0" Foreground="{DynamicResource TextSecondary}" FontSize="14" Margin="0,0,4,0"/>
                                <TextBlock x:Name="CountLabelText" Text="{DynamicResource Text_Items}" Foreground="{DynamicResource TextSecondary}" FontSize="14"/>
                            </StackPanel>

                            <Path StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" VerticalAlignment="Center">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="M0,0 L4,4 L8,0" />
                                        <Setter Property="Stroke" Value="{DynamicResource TextSecondary}" />

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=ExpandButton}" Value="True">
                                                <Setter Property="Data" Value="M0,4 L4,0 L8,4" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>

                        </StackPanel>
                    </ToggleButton>

                    <Popup IsOpen="{Binding IsChecked, ElementName=ExpandButton}" PlacementTarget="{Binding ElementName=MainContainer}" Placement="Custom" AllowsTransparency="True"
                           StaysOpen="False" CustomPopupPlacementCallback="Popup_PlacementCallback" Closed="Popup_Closed">

                        <Border Width="515" Height="300" Background="{DynamicResource MicaBase}" BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="1" CornerRadius="12" Margin="16"
                                PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp" MouseMove="Window_MouseMove">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="28" Color="#000000" Opacity="0.14" Direction="270" ShadowDepth="8"/>
                            </Border.Effect>

                            <Grid TextElement.FontFamily="Segoe UI Variable Text, Segoe UI" TextOptions.TextFormattingMode="Display">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="0,0,0,1">
                                    <Grid Margin="16,0">

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <CheckBox x:Name="SelectAllCheckBox" Content="{DynamicResource Text_SelectAll}" Margin="8,0,0,0" Padding="6,1,0,0"
                                                      Foreground="{DynamicResource TextPrimary}" FontSize="14" VerticalAlignment="Center" VerticalContentAlignment="Center" 
                                                      Cursor="Hand" Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="PopupCountNumberText" Text="0" Foreground="{DynamicResource TextPrimary}" FontSize="14"/>
                                            <TextBlock x:Name="PopupCountLabelText" Text="{DynamicResource Text_Items}" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="4,0,0,0"/>
                                            <TextBlock x:Name="PopupCountSizeText" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="4,0,0,0"/>
                                        </StackPanel>

                                        <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="{DynamicResource MicaBase}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1" CornerRadius="6" Padding="2">
                                            <StackPanel Orientation="Horizontal">

                                                <Border Tag="List" MouseLeftButtonDown="ViewMode_Click" Cursor="Hand" CornerRadius="4" Padding="8,5" Width="34">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CurrentViewMode}" Value="List">
                                                                    <Setter Property="Background" Value="{DynamicResource LayerDefault}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Viewbox Width="15" Height="15" HorizontalAlignment="Center">
                                                        <Canvas Width="24" Height="24">
                                                            <Path StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M8,6 L21,6 M8,12 L21,12 M8,18 L21,18 M2.5,6 L3.5,6 M2.5,12 L3.5,12 M2.5,18 L3.5,18">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Stroke" Value="{DynamicResource TextSecondary}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding CurrentViewMode}" Value="List">
                                                                                <Setter Property="Stroke" Value="{DynamicResource AccentDefault}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                        </Canvas>
                                                    </Viewbox>
                                                </Border>

                                                <Border Tag="Grid" MouseLeftButtonDown="ViewMode_Click" Cursor="Hand" CornerRadius="4" Padding="8,5" Width="34">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CurrentViewMode}" Value="Grid">
                                                                    <Setter Property="Background" Value="{DynamicResource LayerDefault}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Viewbox Width="15" Height="15" HorizontalAlignment="Center">
                                                        <Canvas Width="24" Height="24">
                                                            <Path StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M3,3 h7 v7 h-7 Z M14,3 h7 v7 h-7 Z M14,14 h7 v7 h-7 Z M3,14 h7 v7 h-7 Z">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Stroke" Value="{DynamicResource TextSecondary}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding CurrentViewMode}" Value="Grid">
                                                                                <Setter Property="Stroke" Value="{DynamicResource AccentDefault}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                        </Canvas>
                                                    </Viewbox>
                                                </Border>

                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <ListBox x:Name="ItemsListBox" Grid.Row="1" Margin="8,6,8,8" Padding="0" ItemsSource="{Binding PocketedItems}" SelectionMode="Multiple" 
                                         Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         PreviewMouseMove="ItemsList_PreviewMouseMove" SelectionChanged="ItemsListBox_SelectionChanged"
                                         Style="{StaticResource PocketListBoxStyle}" ItemContainerStyle="{StaticResource PocketListBoxItemStyle}">
                                </ListBox>

                                <Button x:Name="DeleteSelectedButton" Grid.Row="2" Click="DeleteSelected_Click" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,4,32,12" 
                                        Width="40" Height="40" Background="{DynamicResource LayerAlt}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1" Cursor="Hand"
                                        Template="{StaticResource DeleteButtonTemplate}">
                                </Button>

                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="DragGlowBorder" Margin="12" BorderBrush="{DynamicResource BrandAccent}" BorderThickness="6" CornerRadius="12" Visibility="Collapsed" IsHitTestVisible="False"/>

    </Grid>
</Window>