<Window x:Class="PocketDrop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PocketDrop" Height="200" Width="200"
        AllowsTransparency="True" WindowStyle="None" Topmost="True" Background="Transparent"
        UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>
        <DataTemplate x:Key="GridTemplate">
            <StackPanel Margin="10,10,20,10" Width="120" UseLayoutRounding="True">
                <Grid Width="100" Height="100">
                    <!-- Shadow is a SIBLING to Image, never an ancestor.
                         This is the only way to avoid WPF rasterizing the Image. -->

                    <Image Source="{Binding Icon}" Stretch="Uniform"
                           UseLayoutRounding="True" SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>

                <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="#FF333333" 
                   TextAlignment="Center" TextTrimming="CharacterEllipsis" 
                   Margin="0,8,0,0" FontWeight="Medium"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ListTemplate">
            <Grid Margin="5,5" Width="410">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Source="{Binding Icon}" Width="50" Height="50" HorizontalAlignment="Center"
               UseLayoutRounding="True" SnapsToDevicePixels="True"
               RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.15" Direction="270" ShadowDepth="1"/>
                    </Image.Effect>
                </Image>

                <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center" 
                   FontSize="13" Foreground="#FF333333" Margin="15,0,0,0" 
                   TextTrimming="CharacterEllipsis" FontWeight="Medium"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="MainContainer" Margin="10" Background="#FFEBEBEB" BorderBrush="#FFD0D0D0" BorderThickness="1" CornerRadius="8"
            AllowDrop="True" Drop="Window_Drop" PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
            PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp" MouseMove="Window_MouseMove">

        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.15" Direction="270" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,5,10,10" x:Name="TopBar" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Line x:Name="DragHandle" X1="0" Y1="0" X2="40" Y2="0" Stroke="Black" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock x:Name="CloseButton" Text="✕" FontSize="16" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="CloseButton_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="10">
                <TextBlock x:Name="StatusText" Text="Drop items here" FontSize="18" Foreground="#FF6F6F6F" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                <!-- Shadow Border is a SIBLING to Image in a Grid, never an ancestor.
                     FileIconContainer controls overall visibility. -->
                <Grid x:Name="FileIconContainer" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Margin="10" MaxWidth="160" MaxHeight="100" UseLayoutRounding="True">

                    <Image x:Name="FileIcon" Stretch="Uniform"
                           UseLayoutRounding="True" SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10">
                <ToggleButton x:Name="ExpandButton" Cursor="Hand" Background="White" BorderBrush="#FFD0D0D0" BorderThickness="1">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10,3,10,3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="CountText" Text="0 Items" Foreground="#FF6F6F6F" Margin="0,0,10,0"/>
                        <TextBlock Text="v" Foreground="#FF6F6F6F" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>

                <Popup IsOpen="{Binding IsChecked, ElementName=ExpandButton}" PlacementTarget="{Binding ElementName=ExpandButton}" Placement="Bottom" AllowsTransparency="True" StaysOpen="False" HorizontalOffset="-215" VerticalOffset="20">
                    <Border Width="500" Height="300" Background="#FFEBEBEB" BorderBrush="#FFD0D0D0" BorderThickness="1" CornerRadius="8" Margin="15"
                            PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp" MouseMove="Window_MouseMove">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.15" Direction="270" ShadowDepth="0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="20,10,20,0">
                                <TextBlock Text="⚙" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="#FF6F6F6F" FontSize="18" Cursor="Hand"/>
                                <TextBlock x:Name="PopupCountText" Text="0 items" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF6F6F6F" FontWeight="SemiBold"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Tag="List" MouseLeftButtonDown="ViewMode_Click" Cursor="Hand" Padding="10,6" CornerRadius="3,0,0,3" BorderBrush="#FFD0D0D0" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentViewMode}" Value="List">
                                                        <Setter Property="Background" Value="#FFE0E0E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <!-- list.svg (Feather) converted to WPF Path -->
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Data="M8,6 L21,6 M8,12 L21,12 M8,18 L21,18 M2.5,6 L3.5,6 M2.5,12 L3.5,12 M2.5,18 L3.5,18">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Stroke" Value="#FF6F6F6F"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CurrentViewMode}" Value="List">
                                                                    <Setter Property="Stroke" Value="#FF0056D2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <Border Tag="Grid" MouseLeftButtonDown="ViewMode_Click" Cursor="Hand" Padding="10,6" CornerRadius="0,3,3,0" BorderBrush="#FFD0D0D0" BorderThickness="0,1,1,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentViewMode}" Value="Grid">
                                                        <Setter Property="Background" Value="#FFE0E0E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <!-- grid.svg (Feather) converted to WPF Path -->
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                      Data="M3,3 h7 v7 h-7 Z M14,3 h7 v7 h-7 Z M14,14 h7 v7 h-7 Z M3,14 h7 v7 h-7 Z">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Stroke" Value="#FF6F6F6F"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CurrentViewMode}" Value="Grid">
                                                                    <Setter Property="Stroke" Value="#FF0056D2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <ScrollViewer Grid.Row="1" Margin="10,0,10,10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding PocketedItems}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="ItemTemplate" Value="{StaticResource GridTemplate}"/>
                                            <Setter Property="ItemsPanel">
                                                <Setter.Value>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                                    </ItemsPanelTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentViewMode}" Value="List">
                                                    <Setter Property="ItemTemplate" Value="{StaticResource ListTemplate}"/>
                                                    <Setter Property="ItemsPanel">
                                                        <Setter.Value>
                                                            <ItemsPanelTemplate>
                                                                <VirtualizingStackPanel Orientation="Vertical"/>
                                                            </ItemsPanelTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>
            </StackPanel>
        </Grid>
    </Border>
</Window>