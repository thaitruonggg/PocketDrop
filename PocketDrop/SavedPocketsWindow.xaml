<Window x:Class="PocketDrop.SavedPocketsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Text_SavedPocketsTitle}" Height="550" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="Manual" Topmost="True"
        Loaded="Window_Loaded"
        ShowInTaskbar="False"
        Deactivated="Window_Deactivated"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5"
        Icon="/Assets/PocketDrop.ico">

    <Window.Resources>
        <Style x:Key="FluentToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackgroundBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource IconHaloBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource LayerDefault}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="WindowScale" ScaleX="1" ScaleY="1"/>
            <TranslateTransform x:Name="WindowTranslate" Y="0"/>
        </TransformGroup>
    </Window.RenderTransform>

    <Border Background="{DynamicResource MicaBase}" 
        BorderBrush="{DynamicResource StrokeCardDefault}" 
        BorderThickness="1" 
        CornerRadius="12,12,0,0" 
        Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.15" Color="Black" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="EmptyStateText" 
               Text="{DynamicResource Text_EmptyPockets}" TextWrapping="Wrap"
               TextAlignment="Center" VerticalAlignment="Center" 
               Foreground="{DynamicResource TextSecondary}" 
               FontSize="14" Margin="20"/>

            <ListBox x:Name="HistoryListBox" Background="Transparent" BorderThickness="0" 
         Visibility="Collapsed" Margin="10,10,10,0" 
         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" CornerRadius="8" Background="Transparent" Padding="0">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource IconHaloBackground}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource LayerDefault}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="{Binding Icon}" Width="48" Height="48"/>
                            <TextBlock Grid.Column="1" Text="{Binding FileName}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="1" 
                Background="{DynamicResource LayerAlt}" 
                BorderBrush="{DynamicResource StrokeControlDefault}" 
                BorderThickness="0,1,0,0" 
                CornerRadius="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">

                    <Button Style="{StaticResource FluentToolbarButton}" 
                            Width="34" Height="34" Margin="0,0,5,0" Click="AddPocket_Click" Cursor="Hand" 
                            ToolTip="{DynamicResource Text_AddPocketTooltip}" ToolTipService.Placement="Center" ToolTipService.VerticalOffset="-35">
                        <Viewbox Width="20" Height="20">
                            <Path Data="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z M12 8V16 M8 12H16" 
                                  Stroke="{DynamicResource TextSecondary}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                        </Viewbox>
                    </Button>

                    <Button x:Name="TrashButton" 
                            Style="{StaticResource FluentToolbarButton}" 
                            Width="34" Height="34" Margin="0,0,5,0" Click="Trash_Click" Cursor="Hand" 
                            ToolTip="{DynamicResource Text_DeleteAllTooltip}" ToolTipService.Placement="Center" ToolTipService.VerticalOffset="-35">
                        <Viewbox Width="20" Height="20">
                            <Path Data="M3 6H21 M19 6V20C19 21.1046 18.1046 22 17 22H7C5.89543 22 5 21.1046 5 20V6 M8 6V4C8 2.89543 8.89543 2 10 2H14C15.1046 2 16 2.89543 16 4V6 M10 11V17 M14 11V17" 
                                  Stroke="{DynamicResource TextSecondary}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                        </Viewbox>
                    </Button>

                    <Button Style="{StaticResource FluentToolbarButton}" 
                            Width="34" Height="34" Click="Settings_Click" Cursor="Hand" 
                            ToolTip="{DynamicResource Text_SettingsTooltip}" ToolTipService.Placement="Center" ToolTipService.VerticalOffset="-35">
                        <Viewbox Width="20" Height="20">
                            <Path Data="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" 
                                  Stroke="{DynamicResource TextSecondary}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                        </Viewbox>
                    </Button>

                </StackPanel>
            </Border>

            <Popup x:Name="DeleteConfirmPopup" AllowsTransparency="True" StaysOpen="False" Placement="Top" VerticalOffset="-20">
                <Border Background="{DynamicResource LayerDefault}" 
            BorderBrush="{DynamicResource StrokeCardDefault}" 
            BorderThickness="1" 
            CornerRadius="12" 
            Margin="25,15" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.2" Direction="270" Color="Black"/>
                    </Border.Effect>

                    <StackPanel Width="220">
                        <TextBlock Text="{DynamicResource Text_ClearAllPocketsTitle}"
                       Foreground="{DynamicResource TextPrimary}" 
                       FontWeight="SemiBold"
                       FontSize="16" Margin="0,0,0,8"
                       TextAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Text_ClearAllPocketsDesc}"
                       Foreground="{DynamicResource TextSecondary}" 
                       FontSize="13" Margin="0,0,0,20" 
                       TextAlignment="Center"
                       TextWrapping="Wrap" LineHeight="18"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="{DynamicResource Text_Cancel}" Margin="0,0,6,0"
                        Style="{StaticResource FluentToolbarButton}"
                        Foreground="{DynamicResource TextPrimary}"
                        FontSize="13"
                        Height="36" 
                        Click="CloseDeletePopup_Click"/>

                            <Button Grid.Column="1" Content="{DynamicResource Text_Delete}"
                        Style="{StaticResource FluentToolbarButton}"
                        Background="#C42B1C" 
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Height="36" 
                        Click="ConfirmDelete_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Popup>

        </Grid>
    </Border>
</Window>