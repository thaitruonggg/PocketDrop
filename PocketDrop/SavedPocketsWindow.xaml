<Window x:Class="PocketDrop.SavedPocketsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saved Pockets" Height="550" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="Manual" Topmost="True"
        Loaded="Window_Loaded"
        ShowInTaskbar="False"
        Deactivated="Window_Deactivated">

    <Border Background="#F3F5F7" CornerRadius="12,12,0,0" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="EmptyStateText" 
                       Text="Your pockets will appear here&#x0a;when you close them."
                       TextAlignment="Center" VerticalAlignment="Center" 
                       Foreground="#666666" FontSize="14" Margin="20"/>

            <ListBox x:Name="HistoryListBox" Background="Transparent" BorderThickness="0" 
                     Visibility="Collapsed" Margin="10,10,10,0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,10,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Source="{Binding Icon}" Width="48" Height="48" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1" Text="{Binding FileName}" 
                                       VerticalAlignment="Center" Margin="15,0,10,0" 
                                       TextTrimming="CharacterEllipsis" FontSize="16" 
                                       Foreground="#222222" ToolTip="{Binding FileName}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="1" Background="#E5E8EB" CornerRadius="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">

                    <Button Background="Transparent" BorderThickness="0" Width="34" Height="34" Margin="0,0,5,0" Click="AddPocket_Click" Cursor="Hand" 
                            ToolTip="Add new pocket" ToolTipService.Placement="Center" ToolTipService.VerticalOffset="-35">
                        <Viewbox Width="20" Height="20">
                            <Path Data="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z M12 8V16 M8 12H16" 
                                  Stroke="#555" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                        </Viewbox>
                    </Button>

                    <Button x:Name="TrashButton" Background="Transparent" BorderThickness="0" Width="34" Height="34" Margin="0,0,5,0" Click="Trash_Click" Cursor="Hand" 
                            ToolTip="Delete all pockets" ToolTipService.Placement="Center" ToolTipService.VerticalOffset="-35">
                        <Viewbox Width="20" Height="20">
                            <Path Data="M3 6H21 M19 6V20C19 21.1046 18.1046 22 17 22H7C5.89543 22 5 21.1046 5 20V6 M8 6V4C8 2.89543 8.89543 2 10 2H14C15.1046 2 16 2.89543 16 4V6 M10 11V17 M14 11V17" 
                                  Stroke="#555" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                        </Viewbox>
                    </Button>

                    <Button Background="Transparent" BorderThickness="0" Width="34" Height="34" Click="Close_Click" Cursor="Hand" 
                            ToolTip="Settings" ToolTipService.Placement="Center" ToolTipService.VerticalOffset="-35">
                        <Viewbox Width="20" Height="20">
                            <Path Data="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" 
                                  Stroke="#555" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                        </Viewbox>
                    </Button>

                </StackPanel>
            </Border>

            <Popup x:Name="DeleteConfirmPopup" AllowsTransparency="True" StaysOpen="False" Placement="Top" VerticalOffset="-10">
                <Border Background="#FFFFFF" CornerRadius="6" Margin="15" Padding="15,15,15,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Are you sure you want to delete&#x0a;all saved pockets?" 
                                   Foreground="#222222" FontSize="14" Margin="0,0,0,12" LineHeight="20"/>

                        <Button Content="Yes, delete all pockets" Click="ConfirmDelete_Click"
                                Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" 
                                Foreground="#222222" Padding="10,6" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

        </Grid>
    </Border>
</Window>