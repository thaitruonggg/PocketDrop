<Window x:Class="PocketDrop.ShortcutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Text_EditShortcutTitle}" Height="360" Width="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        Loaded="Window_Loaded" PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">

    <Window.Resources>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#005FB8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#004A91"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#003E7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource LayerDefault}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource IconHaloBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource LayerAlt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>


    <Border Background="{DynamicResource LayerDefault}" BorderBrush="{DynamicResource StrokeCardDefault}" BorderThickness="1" CornerRadius="8" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15" Direction="270" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="24,24,24,0">
                <TextBlock x:Name="TitleText" Text="{DynamicResource Text_ChangeShortcute}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>

                <TextBlock FontSize="14" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,40">
                    <Run Text="{DynamicResource Text_ShortcutRule1}"/><Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Text="{DynamicResource Text_ShortcutRuleMods}"/><Run Text="{DynamicResource Text_ShortcutRuleOr}"/><Run FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Text="{DynamicResource Text_ShortcutRuleShift}"/>
                </TextBlock>

                <StackPanel x:Name="DialogKeysContainer" Orientation="Horizontal" HorizontalAlignment="Center" MinHeight="44"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal" Cursor="Hand" MouseLeftButtonDown="Reset_Click" Margin="0,0,24,0" Background="Transparent">
                        <Path Data="M 12 4 C 7.58 4 4 7.58 4 12 C 4 16.42 7.58 20 12 20 C 15.73 20 18.84 17.45 19.73 14 H 17.65 C 16.83 16.33 14.61 18 12 18 C 8.69 18 6 15.31 6 12 C 6 8.69 8.69 6 12 6 C 13.66 6 15.14 6.69 16.22 7.78 L 13 11 H 20 V 4 L 17.65 6.35 C 16.2 4.9 14.21 4 12 4 Z" 
                              Fill="{DynamicResource AccentDefault}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Text_Reset}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AccentDefault}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Cursor="Hand" MouseLeftButtonDown="Clear_Click" Background="Transparent">
                        <Path Data="M 19 6.41 L 17.59 5 L 12 10.59 L 6.41 5 L 5 6.41 L 10.59 12 L 5 17.59 L 6.41 19 L 12 13.41 L 17.59 19 L 19 17.59 L 13.41 12 L 19 6.41 Z" 
                              Fill="{DynamicResource AccentDefault}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Text_Clear}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AccentDefault}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Background="{DynamicResource LayerAlt}" BorderBrush="{DynamicResource StrokeControlDefault}" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="{DynamicResource Text_Save}" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Grid.Column="1" Content="{DynamicResource Text_Cancel}" Click="Cancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>